# ── Auth ──────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# ── Email (Brevo HTTP API — free, works on any host) ──────────
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_FROM_EMAIL=senithudara0000@gmail.com
BREVO_FROM_NAME=ReefSense

# ── AHP Scoring Service (HuggingFace Space) ───────────────────
